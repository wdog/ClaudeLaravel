# ============================================================================
# Docker Environment Configuration Example
# Copy to .env and customize as needed
# ============================================================================

# Application Environment
# - local: Development mode (Vite HMR, debug enabled)
# - production: Production mode (optimized, cache enabled)
# NOTE: This is read from src/.env inside the container
APP_ENV=local

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

# MySQL Root Password
MYSQL_ROOT_PASSWORD=secret

# Laravel Configuration
# Set this to true to run migrations automatically on container start
AUTO_MIGRATE=false

# Queue Worker (optional)
QUEUE_WORKER_ENABLED=true

# Scheduler (disable in development, enable in production)
SCHEDULER_ENABLED=false

# Vite Dev Server (development only)
VITE_DEV_SERVER_ENABLED=true

# Redis Configuration (if enabled)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=null

# Timezone
TZ=Europe/Rome
