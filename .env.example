# ============================================================================
# Docker Environment Configuration Example
# This file is for Docker-level configuration (optional)
# Laravel's actual .env should be in src/.env
# ============================================================================

# ============================================================================
# Build Configuration
# ============================================================================
# Docker build target (production or development)
BUILD_TARGET=production

# ============================================================================
# Service Control
# ============================================================================
# Enable/disable optional services

# Laravel Scheduler (cron jobs)
# Set to "true" in production, "false" in development (use manual: php artisan schedule:run)
SCHEDULER_ENABLED=true

# Laravel Queue Worker
# Set to "true" if you use queues, "false" to disable
QUEUE_WORKER_ENABLED=true

# Vite Dev Server (development only)
# Automatically enabled when APP_ENV=local in src/.env
VITE_DEV_SERVER_ENABLED=false

# ============================================================================
# Container Configuration
# ============================================================================
# Timezone
TZ=Europe/Rome

# ============================================================================
# Notes
# ============================================================================
# Most Laravel configuration should be in src/.env (Laravel's environment file)
# This file is only for Docker-specific settings that are not part of Laravel
#
# The docker-compose.yml will read environment from src/.env automatically
# You can override specific values here if needed, but it's not recommended
